# App
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1d
OTP_EXPIRES_MINUTES=10
OTP_DEBUG_EXPOSE=false
GOOGLE_CLIENT_ID=
MAILTRAP_TOKEN=
MAILTRAP_SENDER_EMAIL=hello@demomailtrap.co
MAILTRAP_SENDER_NAME=PulseWise

# Cloudinary (Avatar upload signed flow)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_UPLOAD_FOLDER=pulsewise/avatar
CLOUDINARY_AVATAR_MAX_BYTES=2097152
CLOUDINARY_AVATAR_MAX_WIDTH=512
CLOUDINARY_AVATAR_MAX_HEIGHT=512
CLOUDINARY_AVATAR_ALLOWED_FORMATS=jpg,jpeg,png,webp
CLOUDINARY_AVATAR_QUALITY=auto:good

# ML microservice (Flask)
ML_SERVICE_BASE_URL=http://localhost:8080
ML_SERVICE_TIMEOUT_MS=20000
ML_SERVICE_VERSION=3
ML_SERVICE_PORT=8080

# PostgreSQL (Docker local default)
POSTGRES_USER=pulsewise
POSTGRES_PASSWORD=pulsewise123
POSTGRES_DB=pulsewise
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Prisma (optional, recommended for Supabase PostgreSQL)
# Runtime database URL. For Prisma Accelerate use prisma://... here.
DATABASE_URL=
# Direct database URL for Prisma CLI and internal PostgreSQL fallbacks.
# When using Prisma Accelerate, set this to your direct PostgreSQL URL.
DIRECT_DATABASE_URL=
# Backward-compatible alias used by the existing Prisma schema directUrl.
# Keep this equal to DIRECT_DATABASE_URL when Prisma Accelerate is enabled.
DIRECT_URL=
# Optional explicit feature flag; Prisma client also auto-enables Accelerate
# when DATABASE_URL starts with prisma://
PRISMA_ACCELERATE_ENABLED=false
# Optional (only needed if you plan to call Supabase APIs)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional tools
PGADMIN_DEFAULT_EMAIL=admin@pulsewise.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Parity workflow (Django vs Node) - optional
PARITY_DJANGO_BASE_URL=
PARITY_DJANGO_TOKEN=
PARITY_DJANGO_WEB_BASE_URL=http://127.0.0.1:8000
PARITY_DJANGO_USERNAME=parityadmin
PARITY_DJANGO_PASSWORD=parity12345
PARITY_DJANGO_THRESHOLD_PATH=../chf-dashboard/hfmonitoring/dashboard/threshold.py
PARITY_NODE_BASE_URL=http://localhost:5000/api/v1
PARITY_NODE_TOKEN=
PARITY_DOCTOR_ID=
PARITY_PATIENT_LIMIT=5
PARITY_DAYS=30
PARITY_PATIENT_IDS=
PARITY_OUTPUT_PATH=docs/parity/golden-django-5p-30d.json
PARITY_INPUT_PATH=docs/parity/golden-django-5p-30d.json
PARITY_REPORT_PATH=docs/parity/parity-report.json
PARITY_TOLERANCE_PATH=docs/parity/parity-tolerance.json
