# App
PORT=5000
NODE_ENV=development
REQUEST_BODY_LIMIT=20mb
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=30d
OTP_EXPIRES_MINUTES=10
OTP_DEBUG_EXPOSE=false
AUTH_RECHECK_USER=true
GOOGLE_CLIENT_ID=
MAILTRAP_TOKEN=
MAILTRAP_SENDER_EMAIL=hello@demomailtrap.co
MAILTRAP_SENDER_NAME=PulseWise

# Browser CORS (native mobile app does not need this; use frontend web origins only, never append /api/v1 here)
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://pulsewise.darrellvalentino.com,https://staging-pulsewise.darrellvalentino.com
CORS_CREDENTIALS=false

# Cloudinary (Avatar upload signed flow)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_UPLOAD_FOLDER=pulsewise/avatar
CLOUDINARY_AVATAR_MAX_BYTES=2097152
CLOUDINARY_AVATAR_MAX_WIDTH=512
CLOUDINARY_AVATAR_MAX_HEIGHT=512
CLOUDINARY_AVATAR_ALLOWED_FORMATS=jpg,jpeg,png,webp
CLOUDINARY_AVATAR_QUALITY=auto:good

# ML microservice (Flask)
ML_SERVICE_BASE_URL=http://localhost:8080
ML_SERVICE_TIMEOUT_MS=20000
ML_SERVICE_VERSION=3
ML_SERVICE_PORT=8080

# Second ML microservice (Heart risk model)
HEART_RISK_ML_SERVICE_BASE_URL=http://localhost:8090
HEART_RISK_ML_SERVICE_TIMEOUT_MS=20000
HEART_RISK_ML_SERVICE_VERSION=1
HEART_RISK_ML_VERSION=heart-risk-v1
HEART_RISK_THRESHOLD=0.43
HEART_RISK_ML_SERVICE_PORT=8090

# Firebase Cloud Messaging (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FCM_ANDROID_CHANNEL_ID=pulsewise_reminders

# Nutrition estimation (Gemini)
NUTRITION_ESTIMATION_ENABLED=false
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NUTRITION_ESTIMATION_MODEL=gemini-3-flash-preview
NUTRITION_ESTIMATION_MODELS=gemini-3.5-flash,gemini-3-flash-preview,gemini-2.5-flash
NUTRITION_ESTIMATION_TIMEOUT_MS=45000
NUTRITION_ESTIMATION_MAX_OUTPUT_TOKENS=1200
NUTRITION_ESTIMATION_THINKING_LEVEL=minimal
NUTRITION_ESTIMATION_MAX_REQUESTS_PER_MINUTE_PER_MODEL=4
NUTRITION_ESTIMATION_MAX_REQUESTS_PER_DAY_PER_MODEL=19
FCM_SCHEDULER_ENABLED=false
MEDICATION_REMINDER_CRON_ENABLED=false
MEDICATION_REMINDER_TIMEZONE=Asia/Jakarta
MEDICATION_REMINDER_LOOKBACK_MINUTES=2
MEDICATION_REMINDER_TICK_MS=60000

# PostgreSQL (Docker local default)
POSTGRES_USER=pulsewise
POSTGRES_PASSWORD=pulsewise123
POSTGRES_DB=pulsewise
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Prisma (optional, recommended for Supabase PostgreSQL)
# Runtime database URL. For Prisma Accelerate use prisma://... here.
DATABASE_URL=
# Direct database URL for Prisma CLI and internal PostgreSQL fallbacks.
# When using Prisma Accelerate, set this to your direct PostgreSQL URL.
DIRECT_DATABASE_URL=
# Backward-compatible alias used by the existing Prisma schema directUrl.
# Keep this equal to DIRECT_DATABASE_URL when Prisma Accelerate is enabled.
DIRECT_URL=
# Optional explicit feature flag; Prisma client also auto-enables Accelerate
# when DATABASE_URL starts with prisma://
PRISMA_ACCELERATE_ENABLED=false
REDIS_ENABLED=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=pw
CACHE_DASHBOARD_LIST_TTL_SECONDS=30
CACHE_DASHBOARD_SUMMARY_TTL_SECONDS=30
CACHE_DASHBOARD_VITALS_TTL_SECONDS=30
CACHE_DASHBOARD_ABNORMAL_REPORT_TTL_SECONDS=30
CACHE_DIARY_BY_DATE_TTL_SECONDS=30
CACHE_SLEEP_BY_DATE_TTL_SECONDS=30
METRICS_ENABLED=false
METRICS_TOKEN=
# Optional (only needed if you plan to call Supabase APIs)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional tools
PGADMIN_DEFAULT_EMAIL=admin@pulsewise.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Parity workflow (Django vs Node) - optional
PARITY_DJANGO_BASE_URL=
PARITY_DJANGO_TOKEN=
PARITY_DJANGO_WEB_BASE_URL=http://127.0.0.1:8000
PARITY_DJANGO_USERNAME=parityadmin
PARITY_DJANGO_PASSWORD=parity12345
PARITY_DJANGO_THRESHOLD_PATH=../chf-dashboard/hfmonitoring/dashboard/threshold.py
PARITY_NODE_BASE_URL=http://localhost:5000
PARITY_NODE_TOKEN=
PARITY_DOCTOR_ID=
PARITY_PATIENT_LIMIT=5
PARITY_DAYS=30
PARITY_PATIENT_IDS=
PARITY_OUTPUT_PATH=docs/parity/golden-django-5p-30d.json
PARITY_INPUT_PATH=docs/parity/golden-django-5p-30d.json
PARITY_REPORT_PATH=docs/parity/parity-report.json
PARITY_TOLERANCE_PATH=docs/parity/parity-tolerance.json
