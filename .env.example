# App
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1d
OTP_EXPIRES_MINUTES=10
OTP_DEBUG_EXPOSE=false
GOOGLE_CLIENT_ID=
MAILTRAP_TOKEN=
