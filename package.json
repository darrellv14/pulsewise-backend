{
  "name": "pulsewise-backend",
  "version": "1.0.0",
  "main": "index.js",
  "description": "PulseWise backend for patient care, doctor dashboard, biometrics, and HFMS ML integration.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "set NODE_ENV=test&& jest --runInBand",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yaml,yml}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node scripts/db/migrate.js",
    "migrate": "npm run db:migrate",
    "seed:dev": "node scripts/seed/seed-dev-users.js",
    "seed:admins": "node scripts/seed/seed-admin-users.js",
    "seed:dashboard": "node scripts/seed/seed-dashboard-data.js",
    "maintenance:education:reset": "node scripts/maintenance/reset-education-cms-and-normalize-admin.js",
    "seed:load-test": "node scripts/seed/seed-load-test-cohort.js",
    "seed:patient-care": "node scripts/seed/seed-patient-care.js",
    "postman:sync-examples": "node scripts/postman/sync-openapi-postman-examples.js",
    "postman:refresh": "node scripts/postman/refresh-postman-collections.js",
    "postman:publish:workspace": "node scripts/postman/publish-postman-workspace.js",
    "postman:smoke:prod": "npx newman run postman/PulseWise-Dashboard-Smoke.postman_collection.json -e postman/environments/PulseWise-Production.postman_environment.json --folder \"Dashboard Smoke E2E\" --folder \"Dashboard ML Smoke\" --reporters cli",
    "postman:capture-live:prod": "node scripts/postman/capture-live-postman-examples.js --collection postman/PulseWise-Dashboard-Smoke.postman_collection.json --environment postman/environments/PulseWise-Production.postman_environment.json --folder \"Dashboard Smoke E2E\" --folder \"Dashboard ML Smoke\"",
    "smoke:hfms:e2e": "node scripts/smoke/smoke-hfms-e2e.js",
    "smoke:heart-risk:local": "node scripts/smoke/smoke-heart-risk-local.js",
    "smoke:education:local": "node scripts/smoke/smoke-education-local.js",
    "smoke:education:prod:safe": "node scripts/smoke/smoke-production-education-delete-account.js",
    "smoke:education:prod:workflow": "node scripts/smoke/smoke-production-education-workflow.js",
    "smoke:fcm:scheduler": "node scripts/smoke/smoke-fcm-scheduler-stage3.js",
    "fcm:test": "node scripts/send_fcm_test.js",
    "smoke:prod": "node scripts/smoke/smoke-live.js",
    "demo:pairing": "node scripts/pairing-demo/server.js",
    "legacy:parity:capture": "node scripts/legacy/dashboard-parity.js capture",
    "legacy:parity:capture:django": "node scripts/legacy/capture-golden-from-django.js",
    "legacy:parity:compare": "node scripts/legacy/dashboard-parity.js compare"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.16.2",
    "@prisma/extension-accelerate": "^2.0.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mailtrap": "^4.5.1",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "prisma": "6.16.2",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  }
}
