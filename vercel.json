{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "git": {
    "deploymentEnabled": false
  },
  "github": {
    "enabled": false,
    "silent": true
  },
  "functions": {
    "api/index.js": {
      "regions": ["sin1"],
      "includeFiles": "{docs/api/openapi.yaml,node_modules/swagger-ui-dist/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
