                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.token) { pm.environment.set('token', json.data.token); }",
                  "if (json?.data?.token) { pm.environment.set('patientToken', json.data.token); }",
                  "if (json?.data?.user?.userId) { pm.environment.set('patientId', json.data.user.userId); }"
                ]
