{
  "info": {
    "name": "PulseWise API (Local)",
    "description": "Collection canonical untuk seluruh endpoint PulseWise (auth, phase-2, dashboard dokter, QR linking).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.user?.userId) { pm.environment.set('patientId', json.data.user.userId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{patientUsername}}\",\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{patientPassword}}\",\n  \"firstName\": \"{{patientFirstName}}\",\n  \"lastName\": \"{{patientLastName}}\",\n  \"role\": \"patient\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST Send Email OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.devOtp) { pm.environment.set('otpCode', json.data.devOtp); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/verifications/email"
          }
        },
        {
          "name": "POST Confirm Email OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status 200', function () { pm.response.to.have.status(200); });"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\",\n  \"otp\": \"{{otpCode}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/verifications/email/confirm"
          }
        },
        {
          "name": "POST Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.token) { pm.environment.set('token', json.data.token); }",
                  "if (json?.data?.token) { pm.environment.set('patientToken', json.data.token); }",
                  "if (json?.data?.user?.userId) { pm.environment.set('patientId', json.data.user.userId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.token) { pm.environment.set('doctorToken', json.data.token); }",
                  "if (json?.data?.user?.userId) { pm.environment.set('doctorId', json.data.user.userId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{doctorPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET Auth Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "POST OAuth Google Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\",\n  \"role\": \"patient\"\n}"
            },
            "url": "{{baseUrl}}/auth/oauth/google"
          }
        }
      ]
    },
    {
      "name": "Care - Patient",
      "item": [
        {
          "name": "GET Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/patients?page=1&limit=20&sortBy=created_at&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["patients"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "sortBy", "value": "created_at" },
                { "key": "order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "GET Patient Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/patients/{{patientId}}/profile"
          }
        },
        {
          "name": "PUT Patient Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{patientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dateOfBirth\": \"1999-12-30\",\n  \"sex\": \"male\"\n}"
            },
            "url": "{{baseUrl}}/patients/{{patientId}}/profile"
          }
        },
        {
          "name": "POST Create Patient Share (Legacy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{patientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expiresInHours\": 24\n}"
            },
            "url": "{{baseUrl}}/patients/{{patientId}}/shares"
          }
        }
      ]
    },
    {
      "name": "Care - Doctor",
      "item": [
        {
          "name": "GET Doctor Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/profile"
          }
        },
        {
          "name": "PUT Doctor Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialization\": \"Cardiology\",\n  \"licenseNo\": \"DOC-123456\",\n  \"hospitalName\": \"RS PulseWise\"\n}"
            },
            "url": "{{baseUrl}}/doctors/{{doctorId}}/profile"
          }
        }
      ]
    },
    {
      "name": "Care - Doctor Patients",
      "item": [
        {
          "name": "POST Link Doctor Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"source\": \"manual\"\n}"
            },
            "url": "{{baseUrl}}/doctors/{{doctorId}}/patients"
          }
        },
        {
          "name": "POST Link By Scanned Patient ID (Primary QR Flow)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"source\": \"qr_patient_id\"\n}"
            },
            "url": "{{baseUrl}}/doctors/{{doctorId}}/patients/link-by-patient-id"
          }
        },
        {
          "name": "POST Link By Share Code (Legacy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shareCode\": \"{{shareCode}}\"\n}"
            },
            "url": "{{baseUrl}}/doctors/{{doctorId}}/patients/link-by-share"
          }
        },
        {
          "name": "GET Doctor Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/doctors/{{doctorId}}/patients?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", "{{doctorId}}", "patients"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "DELETE Doctor Patient Link",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/patients/{{patientId}}"
          }
        }
      ]
    },
    {
      "name": "Care - Doctor Dashboard",
      "item": [
        {
          "name": "GET Dashboard Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients?page=1&limit=20"
          }
        },
        {
          "name": "GET Dashboard Patient Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients/{{patientId}}"
          }
        },
        {
          "name": "GET Dashboard Patient Vitals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients/{{patientId}}/vitals?timePeriod=last_30_days"
          }
        },
        {
          "name": "GET Dashboard Abnormal Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients/{{patientId}}/abnormal-report?timePeriod=last_30_days"
          }
        },
        {
          "name": "POST Create Dashboard Pairing Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.pairingSessionId) { pm.environment.set('pairingSessionId', json.data.pairingSessionId); }",
                  "if (json?.data?.pairingToken) { pm.environment.set('pairingToken', json.data.pairingToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expiresInSeconds\": 90\n}"
            },
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/pairing-sessions"
          }
        },
        {
          "name": "GET Dashboard Pairing Session Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/pairing-sessions/{{pairingSessionId}}"
          }
        },
        {
          "name": "GET Dashboard Pairing Session Events (SSE)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/pairing-sessions/{{pairingSessionId}}/events"
          }
        },
        {
          "name": "POST Confirm Dashboard Pairing (Mobile Patient)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const json = pm.response.json();",
                  "pm.test('Final status returned', function () { pm.expect(['confirmed', 'expired', 'cancelled']).to.include(json?.data?.status); });",
                  "if (json?.data?.pairingSessionId) { pm.environment.set('pairingSessionId', json.data.pairingSessionId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{patientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pairingToken\": \"{{pairingToken}}\",\n  \"source\": \"qr_dashboard_pairing\"\n}"
            },
            "url": "{{baseUrl}}/dashboard/pairing-sessions/confirm"
          }
        }
      ]
    },
    {
      "name": "Biometrics",
      "item": [
        {
          "name": "POST Ingest Biometrics",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{patientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"health_connect\",\n  \"readings\": [\n    {\n      \"metricType\": \"heart_rate\",\n      \"valueNumeric\": 78,\n      \"unit\": \"bpm\",\n      \"measuredAt\": \"2026-04-10T08:00:00.000Z\"\n    },\n    {\n      \"metricType\": \"oxygen_saturation\",\n      \"valueNumeric\": 97,\n      \"unit\": \"%\",\n      \"measuredAt\": \"2026-04-10T08:00:00.000Z\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/biometrics"
          }
        },
        {
          "name": "GET Biometrics History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/biometrics?page=1&limit=50"
          }
        }
      ]
    }
  ]
}
