{
  "info": {
    "name": "PulseWise Dashboard Smoke",
    "description": "Smoke test collection untuk flow dashboard dokter + QR frontend berbasis patientId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Dashboard Smoke E2E",
      "item": [
        {
          "name": "POST Login Seed Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('patientToken', json?.data?.token || '');",
                  "pm.environment.set('patientId', json?.data?.user?.userId || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{seedPatientEmail}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('doctorToken', json?.data?.token || '');",
                  "pm.environment.set('doctorId', json?.data?.user?.userId || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{doctorPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET Dashboard Patients",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status 200', function () { pm.response.to.have.status(200); });"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients?page=1&limit=20"
          }
        },
        {
          "name": "GET Dashboard Patient Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients/{{patientId}}"
          }
        },
        {
          "name": "GET Dashboard Patient Vitals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients/{{patientId}}/vitals?timePeriod=last_30_days"
          }
        },
        {
          "name": "GET Dashboard Abnormal Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/doctors/{{doctorId}}/dashboard/patients/{{patientId}}/abnormal-report?timePeriod=last_30_days"
          }
        },
        {
          "name": "POST Link Doctor By Scanned Patient ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status 201', function () { pm.response.to.have.status(201); });"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"source\": \"qr_patient_id\"\n}"
            },
            "url": "{{baseUrl}}/doctors/{{doctorId}}/patients/link-by-patient-id"
          }
        }
      ]
    }
  ]
}
