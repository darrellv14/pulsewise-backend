  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  article             EducationArticle   @relation(fields: [articleId], references: [articleId], onDelete: Cascade)
  authorUser          User               @relation("EducationArticleRevisionAuthor", fields: [authorUserId], references: [userId], onDelete: Cascade)
  category            EducationCategory? @relation(fields: [categoryId], references: [categoryId], onDelete: SetNull)
  reviewedByUser      User?              @relation("EducationArticleRevisionReviewedBy", fields: [reviewedBy], references: [userId], onDelete: SetNull)

  @@index([articleId, createdAt(sort: Desc)], map: "idx_education_article_revisions_article_created")
  @@index([status, submittedAt(sort: Desc)], map: "idx_education_article_revisions_status_submitted")
  @@map("education_article_revisions")
}

