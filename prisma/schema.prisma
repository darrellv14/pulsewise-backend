  fcmDeviceToken    FcmDeviceToken? @relation(fields: [fcmTokenId], references: [fcmTokenId], onDelete: SetNull)
  requestedByUser   User?           @relation("PushNotificationRequester", fields: [requestedByUserId], references: [userId], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)], map: "idx_push_notification_logs_user_created")
  @@index([dedupeKey], map: "idx_push_notification_logs_dedupe_key")
  @@index([notificationType, createdAt(sort: Desc)], map: "idx_push_notification_logs_type_created")
  @@index([deliveryStatus, createdAt(sort: Desc)], map: "idx_push_notification_logs_status_created")
  @@map("push_notification_logs")
}

