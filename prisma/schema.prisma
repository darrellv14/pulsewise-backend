model PushNotificationLog {
  notificationLogId String          @id @default(dbgenerated("gen_random_uuid()")) @map("notification_log_id") @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  fcmTokenId        String?         @map("fcm_token_id") @db.Uuid
  requestedByUserId String?         @map("requested_by_user_id") @db.Uuid
  dedupeKey         String?         @map("dedupe_key") @db.VarChar(255)
  notificationType  String          @map("notification_type") @db.VarChar(64)
  title             String          @db.VarChar(255)
  body              String
  dataPayload       Json?           @map("data_payload")
  deliveryStatus    String          @default("queued") @map("delivery_status") @db.VarChar(32)
  providerMessageId String?         @map("provider_message_id") @db.VarChar(255)
  providerErrorCode String?         @map("provider_error_code") @db.VarChar(128)
  providerResponse  Json?           @map("provider_response")
  sentAt            DateTime?       @map("sent_at") @db.Timestamptz(6)
  deliveredAt       DateTime?       @map("delivered_at") @db.Timestamptz(6)
  failedAt          DateTime?       @map("failed_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
