model EducationArticle {
  articleId           String                     @id @default(dbgenerated("gen_random_uuid()")) @map("article_id") @db.Uuid
  authorUserId        String                     @map("author_user_id") @db.Uuid
  categoryId          String?                    @map("category_id") @db.Uuid
  slug                String                     @unique @db.VarChar(200)
  title               String                     @db.VarChar(200)
  excerpt             String?                    @db.VarChar(500)
  contentMarkdown     String                     @map("content_markdown")
  coverImageUrl       String?                    @map("cover_image_url")
  coverImagePublicId  String?                    @map("cover_image_public_id") @db.VarChar(255)
  status              String                     @default("draft") @db.VarChar(32)
  visibility          String                     @default("logged_in") @db.VarChar(32)
  approvedBy          String?                    @map("approved_by") @db.Uuid
  approvedAt          DateTime?                  @map("approved_at") @db.Timestamptz(6)
  lastReviewedBy      String?                    @map("last_reviewed_by") @db.Uuid
  lastReviewedAt      DateTime?                  @map("last_reviewed_at") @db.Timestamptz(6)
  rejectionReason     String?                    @map("rejection_reason")
  publishedAt         DateTime?                  @map("published_at") @db.Timestamptz(6)
  isFeatured          Boolean                    @default(false) @map("is_featured")
  featuredOrder       Int?                       @map("featured_order")
  likeCount           Int                        @default(0) @map("like_count")
  commentCount        Int                        @default(0) @map("comment_count")
  viewCount           Int                        @default(0) @map("view_count")
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  authorUser          User                       @relation("EducationArticleAuthor", fields: [authorUserId], references: [userId], onDelete: Cascade)
  category            EducationCategory?         @relation(fields: [categoryId], references: [categoryId], onDelete: SetNull)
  approvedByUser      User?                      @relation("EducationArticleApprovedBy", fields: [approvedBy], references: [userId], onDelete: SetNull)
  lastReviewedByUser  User?                      @relation("EducationArticleLastReviewedBy", fields: [lastReviewedBy], references: [userId], onDelete: SetNull)
  revisions           EducationArticleRevision[]
  images              EducationArticleImage[]
  tags                EducationArticleTag[]
  likes               EducationArticleLike[]
  comments            EducationArticleComment[]

  @@index([authorUserId, createdAt(sort: Desc)], map: "idx_education_articles_author_created")
  @@index([status, publishedAt(sort: Desc), articleId(sort: Desc)], map: "idx_education_articles_status_published")
  @@index([categoryId, publishedAt(sort: Desc), articleId(sort: Desc)], map: "idx_education_articles_category_published")
  @@index([isFeatured, featuredOrder], map: "idx_education_articles_featured")
  @@map("education_articles")
}

model EducationArticleRevision {
  revisionId          String             @id @default(dbgenerated("gen_random_uuid()")) @map("revision_id") @db.Uuid
  articleId           String             @map("article_id") @db.Uuid
  authorUserId        String             @map("author_user_id") @db.Uuid
  categoryId          String?            @map("category_id") @db.Uuid
  slug                String             @db.VarChar(200)
  title               String             @db.VarChar(200)
  excerpt             String?            @db.VarChar(500)
  contentMarkdown     String             @map("content_markdown")
  coverImageUrl       String?            @map("cover_image_url")
  coverImagePublicId  String?            @map("cover_image_public_id") @db.VarChar(255)
  tagSlugs            Json?              @map("tag_slugs")
  status              String             @default("draft") @db.VarChar(32)
  submittedAt         DateTime?          @map("submitted_at") @db.Timestamptz(6)
  reviewedBy          String?            @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?          @map("reviewed_at") @db.Timestamptz(6)
