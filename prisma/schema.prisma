model EducationArticleComment {
  commentId          String                     @id @default(dbgenerated("gen_random_uuid()")) @map("comment_id") @db.Uuid
  articleId          String                     @map("article_id") @db.Uuid
  userId             String                     @map("user_id") @db.Uuid
  parentCommentId    String?                    @map("parent_comment_id") @db.Uuid
  content            String
  status             String                     @default("visible") @db.VarChar(32)
  hiddenBy           String?                    @map("hidden_by") @db.Uuid
  hiddenAt           DateTime?                  @map("hidden_at") @db.Timestamptz(6)
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  article            EducationArticle           @relation(fields: [articleId], references: [articleId], onDelete: Cascade)
  user               User                       @relation("EducationArticleCommentAuthor", fields: [userId], references: [userId], onDelete: Cascade)
  parentComment      EducationArticleComment?   @relation("EducationArticleCommentReplies", fields: [parentCommentId], references: [commentId], onDelete: Cascade)
  replies            EducationArticleComment[]  @relation("EducationArticleCommentReplies")
  hiddenByUser       User?                      @relation("EducationArticleCommentHiddenBy", fields: [hiddenBy], references: [userId], onDelete: SetNull)

  @@index([articleId, createdAt(sort: Desc), commentId(sort: Desc)], map: "idx_education_article_comments_article_created")
  @@index([parentCommentId, createdAt(sort: Asc)], map: "idx_education_article_comments_parent_created")
  @@index([userId, createdAt(sort: Desc)], map: "idx_education_article_comments_user_created")
  @@map("education_article_comments")
}
