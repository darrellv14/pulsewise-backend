generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Role {
  roleId    Int        @id @default(autoincrement()) @map("role_id") @db.SmallInt
  code      String     @unique @db.VarChar(32)
  label     String     @db.VarChar(64)
  userRoles UserRole[]

  @@map("roles")
}

model User {
  userId                           String                    @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  username                         String                    @unique @db.VarChar(100)
  email                            String                    @unique @db.VarChar(255)
  passwordHash                     String                    @map("password_hash")
  firstName                        String?                   @map("first_name") @db.VarChar(100)
  lastName                         String?                   @map("last_name") @db.VarChar(100)
  avatarPhoto                      String?                   @map("avatar_photo")
  googleSub                        String?                   @unique @map("google_sub") @db.VarChar(255)
  address                          String?
  telNo                            String?                   @map("tel_no") @db.VarChar(40)
  isActive                         Boolean                   @default(true) @map("is_active")
  onboardingCompleted              Boolean                   @default(true) @map("onboarding_completed")
  accountStatus                    String                    @default("pending_verification") @map("account_status") @db.VarChar(32)
  emailVerifiedAt                  DateTime?                 @map("email_verified_at") @db.Timestamptz(6)
  createdAt                        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  userRoles                        UserRole[]
  patientProfile                   PatientProfile?
  doctorProfile                    DoctorProfile?
  emergencyContacts                EmergencyContact[]
  heartDiaries                     HeartDiary[]
  patientMlProfile                 PatientMlProfile?
  patientMlAssessments             PatientMlAssessment[]
  patientHeartRiskAssessments      PatientHeartRiskAssessment[]
  patientHeartRiskAssessmentsCreated PatientHeartRiskAssessment[] @relation("PatientHeartRiskAssessmentCreatedBy")
  patientHeartRiskAssessmentsUpdated PatientHeartRiskAssessment[] @relation("PatientHeartRiskAssessmentUpdatedBy")
  patientMlInferenceResults        PatientMlInferenceResult[] @relation("PatientMlInferenceResults")
  medications                      Medication[]
  reminders                        Reminder[]
  medicationLogs                   MedicationLog[]
  emailVerifications               EmailVerification[]
  fcmDeviceTokens                  FcmDeviceToken[]
  vitalSignReadings                VitalSignReading[]
  pushNotificationLogs             PushNotificationLog[]   @relation("PushNotificationRecipient")
  pushNotificationRequests         PushNotificationLog[]   @relation("PushNotificationRequester")
  patientShares                    PatientShare[]            @relation("PatientShares")
  createdPatientShares             PatientShare[]            @relation("PatientShareCreator")
  doctorPatientsAsDoctor           DoctorPatient[]           @relation("DoctorPatientDoctor")
  doctorPatientsAsPatient          DoctorPatient[]           @relation("DoctorPatientPatient")
  dashboardPairingSessionsAsDoctor DashboardPairingSession[] @relation("DashboardPairingSessionDoctor")
  dashboardPairingSessionsAsPatient DashboardPairingSession[] @relation("DashboardPairingSessionPatient")
  requestedMlInferenceResults      PatientMlInferenceResult[] @relation("RequestedMlInferenceResults")
  verifiedDoctorProfiles           DoctorProfile[]            @relation("DoctorVerifiedByUser")
  educationArticlesAuthored        EducationArticle[]         @relation("EducationArticleAuthor")
  educationArticlesApproved        EducationArticle[]         @relation("EducationArticleApprovedBy")
  educationArticlesReviewed        EducationArticle[]         @relation("EducationArticleLastReviewedBy")
  educationArticleRevisionsAuthored EducationArticleRevision[] @relation("EducationArticleRevisionAuthor")
  educationArticleRevisionsReviewed EducationArticleRevision[] @relation("EducationArticleRevisionReviewedBy")
  educationArticleImagesUploaded   EducationArticleImage[]    @relation("EducationArticleImageUploadedBy")
  educationArticleLikes            EducationArticleLike[]
  educationArticleComments         EducationArticleComment[]  @relation("EducationArticleCommentAuthor")
  hiddenEducationArticleComments   EducationArticleComment[]  @relation("EducationArticleCommentHiddenBy")

  @@map("users")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     Int      @map("role_id") @db.SmallInt
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [roleId], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model EmergencyContact {
  emergencyContactId String   @id @default(dbgenerated("gen_random_uuid()")) @map("emergency_contact_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  contactLabel       String   @map("contact_label") @db.VarChar(100)
  contactNumber      String   @map("contact_number") @db.VarChar(50)
  isPriority         Boolean  @default(false) @map("is_priority")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user               User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId], map: "idx_emergency_contacts_user")
  @@map("emergency_contacts")
}

model HeartDiary {
  diaryId            String            @id @default(dbgenerated("gen_random_uuid()")) @map("diary_id") @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  diaryDate          DateTime          @map("diary_date") @db.Date
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  user               User              @relation(fields: [userId], references: [userId], onDelete: Cascade)
  bodyMetrics        DailyBodyMetric[]
  symptoms           DailySymptom[]
  activities         DailyActivity[]
  consumptions       DailyConsumption[]
  sleepRecord        DailySleepRecord?

  @@unique([userId, diaryDate], map: "heart_diaries_user_id_diary_date_key")
  @@index([userId, diaryDate], map: "idx_heart_diaries_user_date")
  @@map("heart_diaries")
}

model DailyBodyMetric {
  metricId           String    @id @default(dbgenerated("gen_random_uuid()")) @map("metric_id") @db.Uuid
  diaryId            String    @map("diary_id") @db.Uuid
  conditionTag       String?   @map("condition_tag") @db.VarChar(64)
  bodyHeight         Decimal?  @map("body_height") @db.Decimal(5, 2)
  bodyWeight         Decimal?  @map("body_weight") @db.Decimal(5, 2)
  bmi                Decimal?  @db.Decimal(5, 2)
  systolicPressure   Int?      @map("systolic_pressure")
  diastolicPressure  Int?      @map("diastolic_pressure")
  heartRate          Int?      @map("heart_rate")
  oxygenSaturation   Int?      @map("oxygen_saturation")
  timeStamp          DateTime  @default(now()) @map("time_stamp") @db.Timestamptz(6)
  heartDiary         HeartDiary @relation(fields: [diaryId], references: [diaryId], onDelete: Cascade)

  @@index([diaryId], map: "idx_daily_metrics_diary")
  @@map("daily_metrics")
}

model DailySymptom {
  symptomId   String    @id @default(dbgenerated("gen_random_uuid()")) @map("symptom_id") @db.Uuid
  diaryId     String    @map("diary_id") @db.Uuid
  symptomName String    @map("symptom_name") @db.VarChar(120)
  symptomCode String?   @map("symptom_code") @db.VarChar(80)
  bodyArea    String?   @map("body_area") @db.VarChar(80)
  isChestPain Boolean?  @map("is_chest_pain")
  painFrequencyCode Int? @map("pain_frequency_code") @db.SmallInt
  painLocationCode Int? @map("pain_location_code") @db.SmallInt
  intensity   Int?      @db.SmallInt
  note        String?
  timeStamp   DateTime  @default(now()) @map("time_stamp") @db.Timestamptz(6)
  heartDiary  HeartDiary @relation(fields: [diaryId], references: [diaryId], onDelete: Cascade)

  @@index([diaryId], map: "idx_daily_symptoms_diary")
  @@map("daily_symptoms")
}

model DailyActivity {
  activityId  String    @id @default(dbgenerated("gen_random_uuid()")) @map("activity_id") @db.Uuid
  diaryId     String    @map("diary_id") @db.Uuid
  name        String    @db.VarChar(120)
  duration    Int?
  heartRate   Int?      @map("heart_rate")
  activityCategory String? @map("activity_category") @db.VarChar(32)
  intensityLevel String? @map("intensity_level") @db.VarChar(32)
  transportMode String? @map("transport_mode") @db.VarChar(32)
  outdoorMinutes Int? @map("outdoor_minutes")
  userFeeling String?   @map("user_feeling") @db.VarChar(80)
  note        String?
  timeStamp   DateTime  @default(now()) @map("time_stamp") @db.Timestamptz(6)
  heartDiary  HeartDiary @relation(fields: [diaryId], references: [diaryId], onDelete: Cascade)

  @@index([diaryId], map: "idx_daily_activities_diary")
  @@map("daily_activities")
}

model DailyConsumption {
  consumptionId String    @id @default(dbgenerated("gen_random_uuid()")) @map("consumption_id") @db.Uuid
  diaryId       String    @map("diary_id") @db.Uuid
  type          String?   @db.VarChar(50)
  name          String?   @db.VarChar(120)
  portion       String?   @db.VarChar(255)
  portionGrams  Decimal?  @map("portion_grams") @db.Decimal(10, 2)
  fdcFoodId     String?   @map("fdc_food_id") @db.VarChar(64)
  nutritionSource String? @map("nutrition_source") @db.VarChar(32)
  energyKcal    Decimal?  @map("energy_kcal") @db.Decimal(10, 2)
  proteinG      Decimal?  @map("protein_g") @db.Decimal(10, 2)
  carbohydrateG Decimal?  @map("carbohydrate_g") @db.Decimal(10, 2)
  sugarG        Decimal?  @map("sugar_g") @db.Decimal(10, 2)
  fiberG        Decimal?  @map("fiber_g") @db.Decimal(10, 2)
  totalFatG     Decimal?  @map("total_fat_g") @db.Decimal(10, 2)
  saturatedFatG Decimal?  @map("saturated_fat_g") @db.Decimal(10, 2)
  monounsaturatedFatG Decimal? @map("monounsaturated_fat_g") @db.Decimal(10, 2)
  polyunsaturatedFatG Decimal? @map("polyunsaturated_fat_g") @db.Decimal(10, 2)
  cholesterolMg Decimal?  @map("cholesterol_mg") @db.Decimal(10, 2)
  calciumMg     Decimal?  @map("calcium_mg") @db.Decimal(10, 2)
  note          String?
  timeStamp     DateTime  @default(now()) @map("time_stamp") @db.Timestamptz(6)
  heartDiary    HeartDiary @relation(fields: [diaryId], references: [diaryId], onDelete: Cascade)

  @@index([diaryId], map: "idx_daily_consumptions_diary")
  @@map("daily_consumptions")
}

model Medication {
  medicationId   String          @id @default(dbgenerated("gen_random_uuid()")) @map("medication_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  name           String          @db.VarChar(120)
  description    String?
  conditionTag   String?         @map("condition_tag") @db.VarChar(64)
  form           String?         @db.VarChar(50)
  color          String?         @db.VarChar(50)
  singleDose     Decimal?        @map("single_dose") @db.Decimal(10, 2)
  singleDoseUnit String?         @map("single_dose_unit") @db.VarChar(32)
  startDate      DateTime?       @map("start_date") @db.Date
  frequency      String          @default("daily") @db.VarChar(16)
  numOfDays      Int?            @map("num_of_days") @db.SmallInt
  note           String?
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  reminders      Reminder[]
  medicationLogs MedicationLog[]

  @@index([userId], map: "idx_medications_user")
  @@map("medications")
}

model Reminder {
  reminderId   String     @id @default(dbgenerated("gen_random_uuid()")) @map("schedule_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  medicationId String     @map("medication_id") @db.Uuid
  scheduleTime DateTime   @map("schedule_time") @db.Time(6)
  dayOfWeek    Int?       @map("day_of_week") @db.SmallInt
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  medication   Medication @relation(fields: [medicationId], references: [medicationId], onDelete: Cascade)

  @@index([userId, medicationId], map: "idx_medication_schedules_user_medication")
  @@map("medication_schedules")
}

model MedicationLog {
  medicationLogId String     @id @default(dbgenerated("gen_random_uuid()")) @map("medication_log_id") @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  medicationId    String     @map("medication_id") @db.Uuid
  status          String     @default("taken") @db.VarChar(16)
  medicationTime  DateTime?  @map("medication_time") @db.Time(6)
  medicationDate  DateTime   @map("medication_date") @db.Date
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  medication      Medication @relation(fields: [medicationId], references: [medicationId], onDelete: Cascade)

  @@index([userId, medicationDate], map: "idx_medication_logs_user_date")
  @@map("medication_logs")
}

model DoctorProfile {
  doctorId         String    @id @map("doctor_id") @db.Uuid
  specialization   String?   @db.VarChar(120)
  licenseNo        String?   @map("license_no") @db.VarChar(120)
  hospitalName     String?   @map("hospital_name") @db.VarChar(150)
  isVerified       Boolean   @default(false) @map("is_verified")
  verifiedAt       DateTime? @map("verified_at") @db.Timestamptz(6)
  verifiedBy       String?   @map("verified_by") @db.Uuid
  verificationNote String?   @map("verification_note")
  rejectionReason  String?   @map("rejection_reason")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User      @relation(fields: [doctorId], references: [userId], onDelete: Cascade)
  verifiedByUser   User?     @relation("DoctorVerifiedByUser", fields: [verifiedBy], references: [userId], onDelete: SetNull)

  @@map("doctor_profiles")
}

model PatientProfile {
  patientId          String    @id @map("patient_id") @db.Uuid
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  sex                String?   @db.VarChar(16)
  bodyHeightCm       Decimal?  @map("body_height_cm") @db.Decimal(5, 2)
  healthConnectPreference String? @map("health_connect_preference") @db.VarChar(32)
  healthConnectStatus     String? @map("health_connect_status") @db.VarChar(32)
  isSmoking          Boolean?  @map("is_smoking")
  isElectricSmoking  Boolean?  @map("is_electric_smoking")
  bloodType          String?   @map("blood_type") @db.VarChar(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user               User      @relation(fields: [patientId], references: [userId], onDelete: Cascade)

  @@map("patient_profiles")
}

model PatientMlProfile {
  patientId         String   @id @map("patient_id") @db.Uuid
  demog1Riagendr    Int?     @map("demog1_riagendr") @db.SmallInt
  demog1Ridreth3    Int?     @map("demog1_ridreth3") @db.SmallInt
  demog1Dmdeduc     Int?     @map("demog1_dmdeduc") @db.SmallInt
  demog1Dmdfmsiz    Int?     @map("demog1_dmdfmsiz") @db.SmallInt
  demog1Dmdhhsiz    Int?     @map("demog1_dmdhhsiz") @db.SmallInt
  demog1Dmdhhsza    Int?     @map("demog1_dmdhhsza") @db.SmallInt
  demog1Dmdhhszb    Int?     @map("demog1_dmdhhszb") @db.SmallInt
  demog1Dmdhhsze    Int?     @map("demog1_dmdhhsze") @db.SmallInt
  demog1Dmdmartl    Int?     @map("demog1_dmdmartl") @db.SmallInt
  quest22Smq020     Int?     @map("quest22_smq020") @db.SmallInt
  quest22Smq890     Int?     @map("quest22_smq890") @db.SmallInt
  quest22Smq900     Int?     @map("quest22_smq900") @db.SmallInt
  quest23Smd470     Int?     @map("quest23_smd470") @db.SmallInt
  quest1Alq111      Int?     @map("quest1_alq111") @db.SmallInt
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  patient           User     @relation(fields: [patientId], references: [userId], onDelete: Cascade)

  @@map("patient_ml_profiles")
}

model PatientMlAssessment {
  assessmentId      String   @id @default(dbgenerated("gen_random_uuid()")) @map("assessment_id") @db.Uuid
  patientId         String   @map("patient_id") @db.Uuid
  assessmentDate    DateTime @map("assessment_date") @db.Date
  exami1Bpxpls      Int?     @map("exami1_bpxpls") @db.SmallInt
  labor1Lbdtcsi     Decimal? @map("labor1_lbdtcsi") @db.Decimal(10, 2)
  labor2Urdflow1    Decimal? @map("labor2_urdflow1") @db.Decimal(10, 2)
  labor2Urdtime1    Decimal? @map("labor2_urdtime1") @db.Decimal(10, 2)
  labor2Urxvol1     Decimal? @map("labor2_urxvol1") @db.Decimal(10, 2)
  quest11Hiq011     Int?     @map("quest11_hiq011") @db.SmallInt
  quest12Heq010     Int?     @map("quest12_heq010") @db.SmallInt
  quest12Heq030     Int?     @map("quest12_heq030") @db.SmallInt
  quest15Kiq022     Int?     @map("quest15_kiq022") @db.SmallInt
  quest15Kiq026     Int?     @map("quest15_kiq026") @db.SmallInt
  quest16Mcq010     Int?     @map("quest16_mcq010") @db.SmallInt
  quest16Mcq160b    Int?     @map("quest16_mcq160b") @db.SmallInt
  quest16Mcq220     Int?     @map("quest16_mcq220") @db.SmallInt
  quest16Mcq300a    Int?     @map("quest16_mcq300a") @db.SmallInt
  quest16Mcq300c    Int?     @map("quest16_mcq300c") @db.SmallInt
  quest17Dpq020     Int?     @map("quest17_dpq020") @db.SmallInt
  quest17Dpq030     Int?     @map("quest17_dpq030") @db.SmallInt
  quest17Dpq040     Int?     @map("quest17_dpq040") @db.SmallInt
  quest20Pfq061b    Int?     @map("quest20_pfq061b") @db.SmallInt
  quest20Pfq061c    Int?     @map("quest20_pfq061c") @db.SmallInt
  quest20Pfq061h    Int?     @map("quest20_pfq061h") @db.SmallInt
  quest3Cdq009      Int?     @map("quest3_cdq009") @db.SmallInt
  quest3Cdq010      Int?     @map("quest3_cdq010") @db.SmallInt
  quest7Diq010      Int?     @map("quest7_diq010") @db.SmallInt
  quest9Dlq050      Int?     @map("quest9_dlq050") @db.SmallInt
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  patient           User     @relation(fields: [patientId], references: [userId], onDelete: Cascade)

  @@unique([patientId, assessmentDate], map: "patient_ml_assessments_patient_id_assessment_date_key")
  @@index([patientId, assessmentDate(sort: Desc)], map: "idx_patient_ml_assessments_patient_date")
  @@map("patient_ml_assessments")
}

model PatientMlInferenceResult {
  resultId         String   @id @default(dbgenerated("gen_random_uuid()")) @map("result_id") @db.Uuid
  patientId        String   @map("patient_id") @db.Uuid
  requestedByUserId String? @map("requested_by_user_id") @db.Uuid
  modelKey         String   @default("hfms") @map("model_key") @db.VarChar(64)
  inferenceType    String   @map("inference_type") @db.VarChar(32)
  requestContext   String?  @map("request_context") @db.VarChar(32)
  mlVersion        String   @map("ml_version") @db.VarChar(64)
  payloadHash      String   @map("payload_hash") @db.VarChar(128)
  payload          Json?    @map("payload")
  sourceSummary    Json?    @map("source_summary")
  windowStartDate  DateTime @map("window_start_date") @db.Date
  windowEndDate    DateTime @map("window_end_date") @db.Date
  upstreamEndpoint String?  @map("upstream_endpoint")
  upstreamStatus   Int?     @map("upstream_status")
  upstreamBody     Json?    @map("upstream_body")
  generatedAt      DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  patient          User     @relation("PatientMlInferenceResults", fields: [patientId], references: [userId], onDelete: Cascade)
  requestedByUser  User?    @relation("RequestedMlInferenceResults", fields: [requestedByUserId], references: [userId], onDelete: SetNull)

  @@index([patientId, modelKey, inferenceType, generatedAt(sort: Desc)], map: "idx_patient_ml_inference_results_patient_model_type_generated")
  @@index([requestedByUserId, generatedAt(sort: Desc)], map: "idx_patient_ml_inference_results_requested_by")
  @@map("patient_ml_inference_results")
}

model PatientHeartRiskAssessment {
  assessmentId        String   @id @default(dbgenerated("gen_random_uuid()")) @map("assessment_id") @db.Uuid
  patientId           String   @map("patient_id") @db.Uuid
  createdByUserId     String?  @map("created_by_user_id") @db.Uuid
  updatedByUserId     String?  @map("updated_by_user_id") @db.Uuid
  assessmentDate      DateTime @map("assessment_date") @db.Date
  age                 Int?     @db.SmallInt
  sex                 Int?     @db.SmallInt
  chestPainType       Int?     @map("chest_pain_type") @db.SmallInt
  restingBpS          Int?     @map("resting_bp_s")
  fastingBloodSugar   Int?     @map("fasting_blood_sugar") @db.SmallInt
  maxHeartRate        Int?     @map("max_heart_rate")
  exerciseAngina      Int?     @map("exercise_angina") @db.SmallInt
  oldPeak             Decimal? @map("old_peak") @db.Decimal(5, 2)
  stSlope             Int?     @map("st_slope") @db.SmallInt
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  patient             User     @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  createdByUser       User?    @relation("PatientHeartRiskAssessmentCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  updatedByUser       User?    @relation("PatientHeartRiskAssessmentUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@unique([patientId, assessmentDate], map: "patient_heart_risk_assessments_patient_id_assessment_date_key")
  @@index([patientId, assessmentDate(sort: Desc)], map: "idx_patient_heart_risk_assessments_patient_date")
  @@index([createdByUserId], map: "idx_patient_heart_risk_assessments_created_by")
  @@index([updatedByUserId], map: "idx_patient_heart_risk_assessments_updated_by")
  @@map("patient_heart_risk_assessments")
}

model DoctorPatient {
  doctorId   String   @map("doctor_id") @db.Uuid
  patientId  String   @map("patient_id") @db.Uuid
  source     String   @default("manual") @db.VarChar(50)
  linkedAt   DateTime @default(now()) @map("linked_at") @db.Timestamptz(6)
  isActive   Boolean  @default(true) @map("is_active")
  doctor     User     @relation("DoctorPatientDoctor", fields: [doctorId], references: [userId], onDelete: Cascade)
  patient    User     @relation("DoctorPatientPatient", fields: [patientId], references: [userId], onDelete: Cascade)

  @@id([doctorId, patientId])
  @@map("doctor_patients")
}

model EmailVerification {
  verificationId String    @id @default(dbgenerated("gen_random_uuid()")) @map("verification_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  email          String    @db.VarChar(255)
  purpose        String    @default("email_verification") @db.VarChar(32)
  otpCodeHash    String    @map("otp_code_hash")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt     DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
